  },
  "description": "Juego de parejas de Rick y Morty",
  "license": "MIT",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "ng": "ng",
    "start": "electron .",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "package": "electron-forge package",
    "make": "electron-forge make",
